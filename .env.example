# Copy to .env (local) or set these in Railway → Variables (production).

# Postgres (admin/content CMS + 칼럼/블로그 posts). Without it the site renders
# from defaults and the /column list is empty; admin post APIs return 503.
# Migrations (incl. the `posts` table) run automatically on server boot.
DATABASE_URL=

# Auth signing secret for the /admin CMS (JWT). Use a long random string.
JWT_SECRET=

# ── Admin login (/admin) ───────────────────────────────────────────────────
# Set ONE of these. HASH is preferred in production (bcrypt hash of the
# password); PLAIN is simpler for local/dev. Generate a hash with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" "여기에비밀번호"
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD=

# ── Image uploads (썸네일 + 에디터 이미지) ────────────────────────────────────
# Local disk / Railway Volume directory for uploaded images (sharp → webp).
# In production, mount a Railway Volume at this path so images survive deploys.
# Defaults to <project>/uploads locally and /app/uploads on Railway.
UPLOAD_DIR=/app/uploads

# ── Contact form email (Resend) ───────────────────────────────────────────
# Get an API key at https://resend.com → API Keys.
RESEND_API_KEY=
# Where inquiries are delivered.
CONTACT_TO_EMAIL=contact@univerlabmedia.co.kr
# Sender. MUST use a domain verified in Resend (Domains → add univerlabmedia.co.kr
# and the DNS records). Before verifying, you can test with the sandbox sender:
#   CONTACT_FROM_EMAIL=유니버랩 미디어 <onboarding@resend.dev>
CONTACT_FROM_EMAIL=유니버랩 미디어 <noreply@univerlabmedia.co.kr>
