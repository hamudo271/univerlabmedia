# Copy to .env (local) or set these in Railway → Variables (production).

# Postgres (admin/content CMS). Without it the site renders from defaults.
DATABASE_URL=

# Auth signing secret for the /admin CMS.
JWT_SECRET=

# ── Analytics ─────────────────────────────────────────────────────────────
# GA4 measurement ID. Optional: the code already defaults to the live property,
# and only univerlabmedia.co.kr reports (localhost/preview builds stay silent).
# Set this only to point a build at a different property. Build-time var, so it
# must exist when Railway builds — not just at runtime.
VITE_GA_ID=

# ── Admin 방문자 통계 (GA4 Data API) ──────────────────────────────────────
# Service-account JSON for the GA4 Data API. Paste the ENTIRE json file
# content as one value (Railway → Variables handles multiline fine).
# The service account email must be added to the GA4 property as Viewer.
# Locally you can point at the file instead: GA_SERVICE_ACCOUNT_FILE=/path/key.json
GA_SERVICE_ACCOUNT_JSON=
# GA4 property id (관리 → 속성 설정 → 속성 ID — 숫자, 측정 ID G-… 아님).
# Without it the server tries auto-discovery via the Analytics Admin API.
GA4_PROPERTY_ID=

# ── Contact form email (Resend) ───────────────────────────────────────────
# Get an API key at https://resend.com → API Keys.
RESEND_API_KEY=
# Where inquiries are delivered.
CONTACT_TO_EMAIL=contact@univerlabmedia.co.kr
# Sender. MUST use a domain verified in Resend (Domains → add univerlabmedia.co.kr
# and the DNS records). Before verifying, you can test with the sandbox sender:
#   CONTACT_FROM_EMAIL=유니버랩 미디어 <onboarding@resend.dev>
CONTACT_FROM_EMAIL=유니버랩 미디어 <noreply@univerlabmedia.co.kr>
