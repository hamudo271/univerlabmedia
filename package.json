{
  "name": "univerlabmedia",
  "homepage": "https://hamudo271.github.io/univerlab/",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"vite\" \"nodemon --watch server --ext js,sql server/index.js\"",
    "dev:vite": "vite",
    "dev:server": "nodemon --watch server --ext js,sql server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "DEPLOY_TARGET=ghpages vite build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.23.25",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lenis": "^1.3.15",
    "lucide-react": "^0.556.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.10.1",
    "serve": "^14.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.17",
